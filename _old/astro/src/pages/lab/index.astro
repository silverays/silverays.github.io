---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('lab', ({ data }) => !data.draft);
entries.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title="AI Lab — Safraz Razik" description="Methodology, experiments, and tooling for AI-accelerated engineering.">
  <section class="container-main section-padding">
    <div class="flex flex-col gap-2 text-center">
      <p class="section-label">Research</p>
      <h1 class="text-3xl font-bold text-gray-900 sm:text-4xl">AI Lab</h1>
      <p class="text-gray-500">Methodology, experiments, and tooling for AI-accelerated engineering.</p>
    </div>
    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {entries.map((entry) => (
        <a href={`/lab/${entry.id}/`} class="card group no-underline">
          <time class="text-xs text-gray-400">{entry.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
          <h2 class="mt-2 text-lg font-bold text-gray-900 transition-colors group-hover:text-primary">{entry.data.title}</h2>
          <p class="mt-2 text-sm text-gray-500">{entry.data.description}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {entry.data.technologies.map((tech) => (
              <span class="rounded-md bg-gray-100 px-2 py-0.5 text-xs text-gray-600">{tech}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
