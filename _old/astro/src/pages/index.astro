---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

const featuredProjects = (await getCollection('projects')).filter((p) => p.data.featured);
featuredProjects.sort((a, b) => b.data.year - a.data.year);

const latestPosts = (await getCollection('posts', ({ data }) => !data.draft));
latestPosts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const clientReviews = (await getCollection('reviews')).filter((r) => r.data.type === 'client');

const renderedClientReviews = await Promise.all(
  clientReviews.map(async (review) => {
    const { Content } = await render(review);
    return { data: review.data, Content };
  })
);
---

<BaseLayout>
  <!-- Hero -->
  <section class="container-main section-padding">
    <div class="mx-auto max-w-3xl text-center">
      <p class="section-label">Zetmel Studio</p>
      <h1 class="text-balance text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl lg:text-6xl">
        AI-Accelerated<br />
        <span class="text-primary">Software Engineering</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-gray-500">
        15+ years of engineering depth combined with LLM-powered workflows.
        From custom compilers to global platforms — delivered faster, without compromise.
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a href="/work/" class="btn-primary">
          View my work
          <i class="ri-arrow-right-line"></i>
        </a>
        <a href="/contact/" class="btn-outline">
          Get in touch
        </a>
      </div>
    </div>
  </section>

  <!-- Methodology -->
  <section class="section-dark section-padding">
    <div class="container-main">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-primary">Methodology</p>
        <h2 class="mt-3 text-3xl font-bold text-white sm:text-4xl">How I Work</h2>
        <p class="mt-4 text-gray-400">
          Senior engineering judgment meets AI acceleration — a structured approach to delivering production-quality software.
        </p>
      </div>
      <div class="mt-16 grid gap-8 md:grid-cols-3">
        <div class="card group">
          <div class="numbered-item">01</div>
          <h3 class="mt-5 text-xl font-bold text-white">Deep Experience</h3>
          <p class="mt-3 leading-relaxed text-gray-400">
            15+ years shipping production software across the stack — web, mobile, desktop, and enterprise. Seasoned engineering judgment to guide every project.
          </p>
        </div>
        <div class="card group">
          <div class="numbered-item">02</div>
          <h3 class="mt-5 text-xl font-bold text-white">AI-Accelerated</h3>
          <p class="mt-3 leading-relaxed text-gray-400">
            Local LLM environments (Ollama, OpenCode, Claude Code) with structured prompting and context-management workflows. Model evaluation for code quality and task fit.
          </p>
        </div>
        <div class="card group">
          <div class="numbered-item">03</div>
          <h3 class="mt-5 text-xl font-bold text-white">Production-Ready</h3>
          <p class="mt-3 leading-relaxed text-gray-400">
            Technical audits, structured milestones, and recovery sprints ensure every deliverable meets production standards. No shortcuts on quality.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Work -->
  <section class="container-main section-padding">
    <div class="flex flex-col gap-2 text-center">
      <p class="section-label">Portfolio</p>
      <h2 class="text-3xl font-bold text-gray-900 sm:text-4xl">Selected Work</h2>
      <p class="text-gray-500">A selection of projects spanning enterprise platforms, open-source tools, and startup products.</p>
    </div>
    <div class="mt-12 grid gap-6 sm:grid-cols-2">
      {featuredProjects.map((project) => (
        <a href={`/work/${project.id}/`} class="card group no-underline">
          <div class="flex items-center gap-3 text-xs text-gray-400">
            <span class="rounded-md bg-primary-light px-2 py-1 font-medium text-primary">{project.data.role}</span>
            <span>{project.data.year}</span>
          </div>
          <h3 class="mt-4 text-xl font-bold text-gray-900 transition-colors group-hover:text-primary">{project.data.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-gray-500">{project.data.summary}</p>
          <div class="mt-5 flex flex-wrap gap-2">
            {project.data.technologies.slice(0, 3).map((tech) => (
              <span class="rounded-md border border-gray-200 px-2.5 py-1 text-xs text-gray-500">{tech}</span>
            ))}
            {project.data.technologies.length > 3 && (
              <span class="text-xs text-gray-400">+{project.data.technologies.length - 3} more</span>
            )}
          </div>
        </a>
      ))}
    </div>
    <div class="mt-10 text-center">
      <a href="/work/" class="btn-outline">
        View all work
        <i class="ri-arrow-right-line"></i>
      </a>
    </div>
  </section>

  <!-- Latest Articles -->
  <section class="section-dark section-padding">
    <div class="container-main">
      <div class="flex flex-col gap-2 text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-primary">Writing</p>
        <h2 class="text-3xl font-bold text-white sm:text-4xl">Latest Articles</h2>
        <p class="text-gray-400">Thoughts on AI-accelerated engineering, model evaluation, and development workflows.</p>
      </div>
      <div class="mt-12 space-y-6">
        {latestPosts.slice(0, 3).map((post, i) => (
          <a href={`/writing/${post.id}/`} class="card group flex items-start gap-5 no-underline">
            <span class="numbered-item mt-1 text-xs font-bold text-primary">{String(i + 1).padStart(2, '0')}</span>
            <div class="min-w-0 flex-1">
              <time class="text-xs text-gray-500">{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
              <h3 class="mt-1 text-lg font-bold text-white transition-colors group-hover:text-primary">{post.data.title}</h3>
              <p class="mt-1 text-sm text-gray-400">{post.data.description}</p>
            </div>
          </a>
        ))}
      </div>
      <div class="mt-10 text-center">
        <a href="/writing/" class="btn-primary">
          All articles
          <i class="ri-arrow-right-line"></i>
        </a>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  {renderedClientReviews.length > 0 && (
    <section class="container-main section-padding">
      <div class="flex flex-col gap-2 text-center">
        <p class="section-label">Testimonials</p>
        <h2 class="text-3xl font-bold text-gray-900 sm:text-4xl">What Clients Say</h2>
      </div>
      <div class="mt-12 grid gap-6 md:grid-cols-2">
        {renderedClientReviews.map((review) => (
          <blockquote class="card">
            <div class="mb-4 flex gap-0.5">
              {Array.from({ length: 5 }).map(() => (
                <i class="ri-star-fill text-sm text-amber-400"></i>
              ))}
            </div>
            <div class="prose-sm leading-relaxed text-gray-600">
              <review.Content />
            </div>
            <footer class="mt-4 text-sm font-semibold text-gray-900">&mdash; {review.data.name}</footer>
          </blockquote>
        ))}
      </div>
    </section>
  )}

  <!-- Open Source -->
  <section class="section-dark section-padding">
    <div class="container-main">
      <div class="flex flex-col gap-2 text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-primary">Open Source</p>
        <h2 class="text-3xl font-bold text-white sm:text-4xl">Tools I've Built</h2>
        <p class="text-gray-400">Libraries and components released to the developer community.</p>
      </div>
      <div class="mt-12 flex flex-wrap justify-center gap-6">
        <a href="https://github.com/safrazik/vue-file-agent" class="card group flex min-w-[18rem] items-center gap-4 no-underline">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary-light text-lg font-bold text-primary">V</div>
          <div>
            <h3 class="text-base font-bold text-white transition-colors group-hover:text-primary">Vue File Agent</h3>
            <p class="text-sm text-gray-400">Vue.js file upload component</p>
          </div>
          <i class="ri-external-link-line ml-auto text-gray-500 transition-colors group-hover:text-primary"></i>
        </a>
        <a href="https://github.com/rockplate/rockplate" class="card group flex min-w-[18rem] items-center gap-4 no-underline">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary-light text-lg font-bold text-primary">R</div>
          <div>
            <h3 class="text-base font-bold text-white transition-colors group-hover:text-primary">Rockplate</h3>
            <p class="text-sm text-gray-400">JavaScript template engine</p>
          </div>
          <i class="ri-external-link-line ml-auto text-gray-500 transition-colors group-hover:text-primary"></i>
        </a>
      </div>
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="container-main section-padding text-center">
    <h2 class="text-3xl font-bold text-gray-900 sm:text-4xl">Work With Me</h2>
    <p class="mx-auto mt-4 max-w-xl text-gray-500">
      Have a project in mind or want to discuss AI-accelerated engineering? Let's talk.
    </p>
    <a href="/contact/" class="btn-primary mt-8">
      Get in touch
      <i class="ri-arrow-right-line"></i>
    </a>
  </section>
</BaseLayout>
