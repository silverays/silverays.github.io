---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts', ({ data }) => !data.draft);
posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title="Writing — Safraz Razik" description="Articles on AI-accelerated engineering, full-stack development, and open-source.">
  <section class="container-main section-padding">
    <div class="flex flex-col gap-2 text-center">
      <p class="section-label">Articles</p>
      <h1 class="text-3xl font-bold text-gray-900 sm:text-4xl">Writing</h1>
      <p class="text-gray-500">Thoughts on AI-accelerated engineering, model evaluation, and development workflows.</p>
    </div>
    <div class="mt-12 space-y-6">
      {posts.map((post, i) => (
        <a href={`/writing/${post.id}/`} class="card group flex items-start gap-5 no-underline">
          <span class="numbered-item mt-1 text-xs font-bold text-primary">{String(i + 1).padStart(2, '0')}</span>
          <div class="min-w-0 flex-1">
            <time class="text-xs text-gray-400">{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
            <h2 class="mt-1 text-lg font-bold text-gray-900 transition-colors group-hover:text-primary">{post.data.title}</h2>
            <p class="mt-1 text-sm text-gray-500">{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <div class="mt-3 flex flex-wrap gap-2">
                {post.data.tags.map((tag) => (
                  <span class="rounded-md bg-gray-100 px-2 py-0.5 text-xs text-gray-600">{tag}</span>
                ))}
              </div>
            )}
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
