---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact — Safraz Razik">
  <section class="container-main section-padding">
    <div class="mx-auto max-w-3xl text-center">
      <p class="section-label">Contact</p>
      <h1 class="text-3xl font-bold text-gray-900 sm:text-4xl">Get in Touch</h1>
      <p class="mt-4 text-gray-500">
        Have a project in mind, want to discuss AI-accelerated engineering, or just say hello?
      </p>
      <div class="mt-12 grid gap-6 sm:grid-cols-3">
        <a href="mailto:safrazik@zetmel.com" class="card group no-underline">
          <i class="ri-mail-line text-2xl text-primary"></i>
          <h3 class="mt-4 text-base font-bold text-gray-900">Email</h3>
          <p class="mt-1 text-sm text-gray-500">safrazik@zetmel.com</p>
        </a>
        <a href="https://linkedin.com/in/safrazik" class="card group no-underline">
          <i class="ri-linkedin-fill text-2xl text-primary"></i>
          <h3 class="mt-4 text-base font-bold text-gray-900">LinkedIn</h3>
          <p class="mt-1 text-sm text-gray-500">Connect with me</p>
        </a>
        <a href="https://github.com/safrazik" class="card group no-underline">
          <i class="ri-github-fill text-2xl text-primary"></i>
          <h3 class="mt-4 text-base font-bold text-gray-900">GitHub</h3>
          <p class="mt-1 text-sm text-gray-500">View my code</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
