---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
projects.sort((a, b) => b.data.year - a.data.year);
---

<BaseLayout title="Work — Safraz Razik" description="Case studies and projects by Safraz Razik.">
  <section class="container-main section-padding">
    <div class="flex flex-col gap-2 text-center">
      <p class="section-label">Portfolio</p>
      <h1 class="text-3xl font-bold text-gray-900 sm:text-4xl">Work</h1>
      <p class="text-gray-500">Selected case studies and projects spanning enterprise platforms, open-source tools, and startup products.</p>
    </div>
    <div class="mt-12 grid gap-6 sm:grid-cols-2">
      {projects.map((project) => (
        <a href={`/work/${project.id}/`} class="card group no-underline">
          <div class="flex items-center gap-3 text-xs text-gray-400">
            <span class="rounded-md bg-primary-light px-2 py-1 font-medium text-primary">{project.data.role}</span>
            <span>{project.data.year}</span>
          </div>
          <h2 class="mt-4 text-xl font-bold text-gray-900 transition-colors group-hover:text-primary">{project.data.title}</h2>
          <p class="mt-2 text-sm leading-relaxed text-gray-500">{project.data.summary}</p>
          <div class="mt-5 flex flex-wrap gap-2">
            {project.data.technologies.slice(0, 4).map((tech) => (
              <span class="rounded-md border border-gray-200 px-2.5 py-1 text-xs text-gray-500">{tech}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
