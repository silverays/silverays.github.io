---
const links = [
  { href: '/work/', label: 'Work' },
  { href: '/lab/', label: 'AI Lab' },
  { href: '/writing/', label: 'Writing' },
  { href: '/about/', label: 'About' },
];
---

<nav x-data="{ open: false }" class="flex items-center">
  <ul class="hidden items-center gap-8 md:flex">
    {links.map((link) => (
      <li>
        <a href={link.href} class="text-sm font-medium text-gray-600 no-underline transition-colors hover:text-primary">
          {link.label}
        </a>
      </li>
    ))}
    <li>
      <pagefind-modal-trigger class="cursor-pointer bg-transparent border-0 p-0 text-sm font-medium text-gray-600 transition-colors hover:text-primary">
        <i class="ri-search-line text-base"></i>
      </pagefind-modal-trigger>
    </li>
  </ul>
  <button @click="open = !open" class="flex items-center gap-2 text-sm font-medium text-gray-600 md:hidden">
    <i class="ri-menu-line text-xl"></i>
  </button>
  <div x-show="open" @click.outside="open = false" class="fixed inset-0 top-16 z-50 bg-white md:hidden" x-cloak>
    <ul class="flex flex-col gap-2 p-6">
      {links.map((link) => (
        <li>
          <a href={link.href} @click="open = false" class="block rounded-lg px-4 py-3 text-base font-medium text-gray-700 no-underline transition-colors hover:bg-gray-50 hover:text-primary">
            {link.label}
          </a>
        </li>
      ))}
      <li class="mt-4 border-t border-gray-200 pt-4">
        <div class="flex items-center gap-4 px-4">
          <pagefind-modal-trigger class="flex items-center gap-2 text-sm font-medium text-gray-600">
            <i class="ri-search-line"></i> Search
          </pagefind-modal-trigger>
        </div>
      </li>
    </ul>
  </div>
</nav>
