---
import Layout from '@layouts/Layout.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
projects.sort((a, b) => b.data.year - a.data.year);
---

<Layout title="Work — Safraz Razik" description="Case studies and projects by Safraz Razik.">
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:max-w-7xl lg:px-8">
      <div class="flex flex-col gap-4 pb-12 text-center">
        <h1 class="text-4xl font-medium tracking-tight sm:text-5xl">Work</h1>
        <p class="text-muted mx-auto max-w-sm text-lg">Selected case studies spanning enterprise platforms, open-source tools, and startup products.</p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2">
        {projects.map((project) => (
          <a href={`/work/${project.id}/`} class="bg-surface group rounded-3xl px-6 py-8 no-underline transition-shadow hover:shadow-lg">
            <div class="flex items-center gap-3 text-xs text-muted">
              <span class="rounded-md bg-primary-100 px-2 py-1 font-medium text-primary-700">{project.data.role}</span>
              <span>{project.data.year}</span>
            </div>
            <h2 class="mt-4 text-xl font-medium text-primary transition-colors group-hover:text-primary-500">{project.data.title}</h2>
            <p class="text-muted mt-2 text-sm leading-relaxed">{project.data.summary}</p>
            <div class="mt-5 flex flex-wrap gap-2">
              {project.data.technologies.slice(0, 4).map((tech) => (
                <span class="border-subtle rounded-md border px-2.5 py-1 text-xs">{tech}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
