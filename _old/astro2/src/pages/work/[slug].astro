---
import Layout from '@layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, summary, role, year, duration, technologies, link, aiRole, context, problem, constraints, outcome } = project.data;
---

<Layout title={`${title} — Safraz Razik`} description={summary}>
  <article class="py-16 sm:py-20">
    <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:max-w-7xl lg:px-8">
      <a href="/work/" class="text-link mb-8 inline-flex items-center gap-1 text-sm">&larr; Back to work</a>

      <div class="mx-auto max-w-3xl">
        <div class="flex flex-wrap items-center gap-3 text-xs">
          <span class="rounded-md bg-primary-100 px-2 py-1 font-medium text-primary-700">{role}</span>
          <span class="text-muted">{year}</span>
          {duration && <><span class="text-muted" aria-hidden="true">&middot;</span><span class="text-muted">{duration}</span></>}
          {link && <a href={link} class="ml-auto text-link" target="_blank" rel="noopener">Live project &rarr;</a>}
        </div>

        <h1 class="mt-4 text-3xl font-medium tracking-tight sm:text-4xl">{title}</h1>
        <p class="text-muted mt-4 text-lg leading-relaxed">{summary}</p>

        <div class="mt-6 flex flex-wrap gap-2">
          {technologies.map((tech) => (
            <span class="border-subtle rounded-md border px-2.5 py-1 text-xs">{tech}</span>
          ))}
        </div>

        <hr class="border-subtle my-10" />

        <div class="text-muted space-y-4 text-base leading-relaxed">
          {context && <section><h2 class="text-primary text-2xl font-medium tracking-tight">Context</h2><p>{context}</p></section>}
          {problem && <section><h2 class="text-primary text-2xl font-medium tracking-tight">Problem</h2><p>{problem}</p></section>}
          {constraints && <section><h2 class="text-primary text-2xl font-medium tracking-tight">Constraints</h2><p>{constraints}</p></section>}
          {aiRole && <section><h2 class="text-primary text-2xl font-medium tracking-tight">Role of AI</h2><p>{aiRole}</p></section>}
          <Content />
          {outcome && <section><h2 class="text-primary text-2xl font-medium tracking-tight">Outcome</h2><p>{outcome}</p></section>}
        </div>
      </div>
    </div>
  </article>
</Layout>
