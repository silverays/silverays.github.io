---
import Layout from '@layouts/Layout.astro';
---

<Layout title="404 — Page Not Found" description="Page not found.">
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:max-w-7xl lg:px-8">
      <div class="flex flex-col items-start gap-8 sm:gap-10">
        <div class="flex flex-col gap-4 sm:gap-6">
          <h1 class="text-4xl font-medium tracking-tight sm:text-5xl lg:text-6xl">
            <div>404</div>
            <div>Page not found</div>
          </h1>
          <p class="text-muted text-lg sm:text-xl">The page you're looking for doesn't exist.</p>
        </div>
        <a href="/" class="btn-primary">Go home</a>
      </div>
    </div>
  </section>
</Layout>
