---
import Layout from '@layouts/Layout.astro';
import Mission from '@components/about/Mission.astro';
import Values from '@components/about/Values.astro';
---

<Layout title="About — Safraz Razik" description="AI-accelerated software engineering by Safraz Razik. 15+ years of full-stack development and startup co-founding.">
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-2xl px-4 text-center sm:px-6 lg:max-w-7xl lg:px-8">
      <div class="flex flex-col gap-4 sm:gap-6">
        <h1 class="text-4xl font-medium tracking-tight sm:text-5xl lg:text-6xl">About</h1>
        <p class="text-muted mx-auto max-w-sm text-lg sm:max-w-lg sm:text-xl">
          Founder of Zetmel — an AI-accelerated software engineering studio.
        </p>
      </div>
    </div>
  </section>
  <Mission />
  <Values />
</Layout>
