---
import Layout from '@layouts/Layout.astro';
---

<Layout title="Style guide — Safraz Razik" description="Design system reference." noindex>
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:max-w-7xl lg:px-8">
      <h1 class="text-4xl font-medium tracking-tight sm:text-5xl">Style guide</h1>
      <div class="mt-12 space-y-16">
        <div>
          <h2 class="text-2xl font-medium tracking-tight sm:text-3xl">Logo</h2>
          <img class="mt-4" src="/logo.svg" width="64" height="64" alt="Logo" />
        </div>
        <div>
          <h2 class="text-2xl font-medium tracking-tight sm:text-3xl">Colors</h2>
          <div class="mt-4 grid grid-cols-2 gap-4 sm:grid-cols-4">
            <div class="rounded-xl bg-primary-50 p-4 text-primary-950">50</div>
            <div class="rounded-xl bg-primary-100 p-4 text-primary-950">100</div>
            <div class="rounded-xl bg-primary-200 p-4 text-primary-950">200</div>
            <div class="rounded-xl bg-primary-300 p-4 text-primary-950">300</div>
            <div class="rounded-xl bg-primary-400 p-4 text-white">400</div>
            <div class="rounded-xl bg-primary-500 p-4 text-white">500</div>
            <div class="rounded-xl bg-primary-600 p-4 text-white">600</div>
            <div class="rounded-xl bg-primary-700 p-4 text-white">700</div>
            <div class="rounded-xl bg-primary-800 p-4 text-white">800</div>
            <div class="rounded-xl bg-primary-900 p-4 text-white">900</div>
            <div class="rounded-xl bg-primary-950 p-4 text-white">950</div>
          </div>
        </div>
        <div>
          <h2 class="text-2xl font-medium tracking-tight sm:text-3xl">Typography</h2>
          <div class="mt-4 space-y-2">
            <p class="text-5xl font-medium tracking-tight">Inter Medium</p>
            <p class="text-3xl font-medium tracking-tight">Inter Medium 3xl</p>
            <p class="text-2xl font-medium tracking-tight">Inter Medium 2xl</p>
            <p class="text-xl">Inter Regular xl</p>
            <p class="text-lg">Inter Regular lg</p>
            <p class="text-base">Inter Regular base</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
