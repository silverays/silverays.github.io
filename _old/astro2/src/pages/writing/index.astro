---
import Layout from '@layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts', ({ data }) => !data.draft);
posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Layout title="Writing — Safraz Razik" description="Articles on AI-accelerated engineering, full-stack development, and open-source.">
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:max-w-7xl lg:px-8">
      <div class="flex flex-col gap-4 pb-12 text-center">
        <h1 class="text-4xl font-medium tracking-tight sm:text-5xl">Writing</h1>
        <p class="text-muted mx-auto max-w-sm text-lg">Thoughts on AI-accelerated engineering, model evaluation, and development workflows.</p>
      </div>
      <div class="space-y-6">
        {posts.map((post, i) => (
          <a href={`/writing/${post.id}/`} class="bg-surface group flex items-start gap-5 rounded-3xl px-6 py-8 no-underline transition-shadow hover:shadow-lg">
            <span class="bg-primary-100 mt-1 flex h-10 w-10 shrink-0 items-center justify-center rounded-xl text-xs font-bold text-primary-700">{String(i + 1).padStart(2, '0')}</span>
            <div class="min-w-0 flex-1">
              <time class="text-xs text-muted">{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
              <h2 class="mt-1 text-lg font-medium text-primary transition-colors group-hover:text-primary-500">{post.data.title}</h2>
              <p class="text-muted mt-1 text-sm">{post.data.description}</p>
              {post.data.tags.length > 0 && (
                <div class="mt-3 flex flex-wrap gap-2">
                  {post.data.tags.map((tag) => (
                    <span class="rounded-md bg-primary-100 px-2 py-0.5 text-xs text-primary-700">{tag}</span>
                  ))}
                </div>
              )}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
