---
import Layout from '@layouts/Layout.astro';
---

<Layout title="Privacy policy — Safraz Razik" description="Privacy policy.">
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:max-w-7xl lg:px-8">
      <h1 class="text-4xl font-medium tracking-tight sm:text-5xl">Privacy policy</h1>
      <div class="text-muted mt-8 space-y-4 text-base leading-relaxed">
        <p>This website does not collect personal data beyond what is necessary for its operation.</p>
        <p><strong>Data collected:</strong> This site uses no analytics, tracking cookies, or third-party data collection services. No personal information is stored on our servers.</p>
        <p><strong>Contact:</strong> If you have questions about this policy, please email safrazik@zetmel.com.</p>
      </div>
    </div>
  </section>
</Layout>
