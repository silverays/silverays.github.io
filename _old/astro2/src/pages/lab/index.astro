---
import Layout from '@layouts/Layout.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('lab', ({ data }) => !data.draft);
entries.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Layout title="AI Lab — Safraz Razik" description="Methodology, experiments, and tooling for AI-accelerated engineering.">
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:max-w-7xl lg:px-8">
      <div class="flex flex-col gap-4 pb-12 text-center">
        <h1 class="text-4xl font-medium tracking-tight sm:text-5xl">AI Lab</h1>
        <p class="text-muted mx-auto max-w-sm text-lg">Methodology, experiments, and tooling for AI-accelerated engineering.</p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {entries.map((entry) => (
          <a href={`/lab/${entry.id}/`} class="bg-surface group rounded-3xl px-6 py-8 no-underline transition-shadow hover:shadow-lg">
            <time class="text-xs text-muted">{entry.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
            <h2 class="mt-2 text-lg font-medium text-primary transition-colors group-hover:text-primary-500">{entry.data.title}</h2>
            <p class="text-muted mt-2 text-sm">{entry.data.description}</p>
            <div class="mt-4 flex flex-wrap gap-2">
              {entry.data.technologies.map((tech) => (
                <span class="rounded-md bg-primary-100 px-2 py-0.5 text-xs text-primary-700">{tech}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
