---
import Layout from '@layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('lab');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, description, pubDate, technologies } = entry.data;
---

<Layout title={`${title} — AI Lab`} description={description}>
  <article class="py-16 sm:py-20">
    <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:max-w-7xl lg:px-8">
      <a href="/lab/" class="text-link mb-8 inline-flex items-center gap-1 text-sm">&larr; Back to AI Lab</a>

      <div class="mx-auto max-w-3xl">
        <time class="text-sm text-muted">{pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
        <h1 class="mt-2 text-3xl font-medium tracking-tight sm:text-4xl">{title}</h1>
        <p class="text-muted mt-4 text-lg leading-relaxed">{description}</p>

        <div class="mt-6 flex flex-wrap gap-2">
          {technologies.map((tech) => (
            <span class="border-subtle rounded-md border px-2.5 py-1 text-xs">{tech}</span>
          ))}
        </div>

        <hr class="border-subtle my-10" />

        <div class="text-muted space-y-4 text-base leading-relaxed">
          <Content />
        </div>
      </div>
    </div>
  </article>
</Layout>
