---
import ExternalLinkIcon from '@assets/icons/external-link-line.svg';
import GitHubIcon from '@assets/icons/github-fill.svg';
import LinkedInIcon from '@assets/icons/linkedin-box-fill.svg';
import QuestionIcon from '@assets/icons/question-answer-line.svg';
---

<section class="py-16 sm:py-20">
  <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:max-w-7xl lg:px-8">
    <div class="flex flex-col items-center gap-8 pb-16 text-center">
      <h1 class="text-4xl font-medium tracking-tight sm:text-5xl">Get in Touch</h1>
      <p class="text-muted max-w-sm text-lg">
        Have a project in mind or want to discuss AI-accelerated engineering? Let's talk.
      </p>
      <a href="mailto:safrazik@zetmel.com" class="btn-primary">
        safrazik@zetmel.com
      </a>
    </div>
    <dl class="grid gap-6 lg:grid-cols-3">
      <div class="bg-surface rounded-3xl px-6 py-8">
        <dt class="sr-only">Email</dt>
        <dd class="flex h-full flex-col justify-between gap-12">
          <QuestionIcon class="icon-primary" aria-hidden="true" />
          <div class="text-base font-medium">
            <a href="mailto:safrazik@zetmel.com" class="text-link">safrazik@zetmel.com</a>
          </div>
        </dd>
      </div>
      <div class="bg-surface rounded-3xl px-6 py-8">
        <dt class="sr-only">LinkedIn</dt>
        <dd class="flex h-full flex-col justify-between gap-12">
          <LinkedInIcon class="icon-primary" aria-hidden="true" />
          <p class="text-base font-medium">
            <a href="https://linkedin.com/in/safrazik" class="text-link" target="_blank" rel="noopener noreferrer">
              linkedin.com/in/safrazik
              <ExternalLinkIcon class="h-4 w-4" aria-hidden="true" />
            </a>
          </p>
        </dd>
      </div>
      <div class="bg-surface rounded-3xl px-6 py-8">
        <dt class="sr-only">GitHub</dt>
        <dd class="flex h-full flex-col justify-between gap-12">
          <GitHubIcon class="icon-primary" aria-hidden="true" />
          <p class="text-base font-medium">
            <a href="https://github.com/safrazik" class="text-link" target="_blank" rel="noopener noreferrer">
              github.com/safrazik
              <ExternalLinkIcon class="h-4 w-4" aria-hidden="true" />
            </a>
          </p>
        </dd>
      </div>
    </dl>
  </div>
</section>
