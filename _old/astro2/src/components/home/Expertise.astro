---
import TargetIcon from '@assets/icons/target-fill.svg';
import AccordionItem from '@components/common/AccordionItem.astro';

const technologies = [
  { id: 'frontend', name: 'Frontend & UI', description: 'JavaScript (ES6+), TypeScript, React, Vue.js, Next.js, Material UI, HTML5, CSS3/SASS/LESS' },
  { id: 'backend', name: 'Backend & Data', description: 'PHP, Node.js, Express.js, MySQL, PostgreSQL, MongoDB, SQLite, Laravel, Symfony' },
  { id: 'enterprise', name: 'Architecture & Enterprise', description: 'Oracle Commerce Cloud (OCC), Oracle Storefront Framework (OSF), Lexer & AST Building' },
  { id: 'mobile', name: 'Mobile & Desktop', description: 'React Native, Electron, Ionic, Cordova, Framework7' },
  { id: 'ai', name: 'AI & LLM Workflows', description: 'Ollama, OpenCode, Claude Code, structured prompting, model evaluation (Qwen, Llama, DeepSeek), technical audits' },
  { id: 'legacy', name: 'Legacy & Maintenance', description: 'Angular, jQuery, WordPress, Durandal, Knockout, ASP.NET MVC, CodeIgniter, Yii, BreezeJS' },
];
---

<section class="py-16 sm:py-20">
  <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:max-w-7xl lg:px-8">
    <div class="grid gap-12 lg:grid-cols-3 lg:gap-8">
      <div class="flex gap-4">
        <TargetIcon class="fill-primary-500 h-8 w-8 shrink-0 sm:h-10 sm:w-10" aria-hidden="true" />
        <h2 class="text-3xl font-medium tracking-tight sm:text-4xl">Technology</h2>
      </div>
      <div class="lg:col-span-2">
        <dl class="-mt-3" x-data="accordion">
          {technologies.map((tech, index) => (
            <AccordionItem id={tech.id} index={index}>
              <span slot="header" class="font-medium">{tech.name}</span>
              <div slot="body" class="pr-6 pb-6">
                <p class="text-muted text-base">{tech.description}</p>
              </div>
            </AccordionItem>
          ))}
        </dl>
      </div>
    </div>
  </div>
</section>
