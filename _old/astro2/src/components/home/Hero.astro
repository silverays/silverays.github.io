---
import { Image } from 'astro:assets';
import heroImg from '@assets/hero.webp';
---

<section class="py-16 sm:py-20">
  <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:max-w-7xl lg:px-8">
    <div class="flex flex-col gap-16">
      <div class="flex flex-col items-start gap-8 sm:gap-10">
        <div class="flex max-w-2xl flex-col items-start gap-4 sm:gap-6">
          <p class="text-muted text-sm font-semibold uppercase tracking-[0.15em]">Zetmel Studio</p>
          <h1 class="relative text-4xl font-medium tracking-tight sm:text-5xl lg:text-6xl">
            AI-Accelerated<br />
            <span class="text-primary-500">Software Engineering</span>
            <span class="from-primary-500/0 to-primary-500 block h-1 bg-linear-to-r sm:h-1.5 lg:h-2"></span>
          </h1>
          <p class="text-muted max-w-md text-lg sm:max-w-lg sm:text-xl">
            15+ years of engineering depth combined with LLM-powered workflows.
            From custom compilers to global platforms — delivered faster, without compromise.
          </p>
        </div>
        <div class="flex flex-wrap gap-4">
          <a href="/work/" class="btn-primary">
            View my work
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
          <a href="/contact/" class="btn-primary bg-primary-300 text-primary-900 hover:bg-primary-400">
            Get in touch
          </a>
        </div>
      </div>
      <Image class="h-auto w-full rounded-3xl" src={heroImg} alt="Hero illustration" priority />
    </div>
  </div>
</section>
