---
import ExternalLinkIcon from '@assets/icons/external-link-line.svg';

const base = import.meta.env.BASE_URL;
---

<footer class="bg-surface mt-16 py-16 lg:mt-20 lg:py-20" aria-labelledby="footer-heading">
  <h2 id="footer-heading" class="sr-only">Footer</h2>
  <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:max-w-7xl lg:px-8">
    <div class="flex flex-col justify-between gap-12 sm:gap-16 lg:flex-row">
      <div class="flex max-w-100 flex-col items-start gap-6 sm:gap-8">
        <a href="/" class="group-focus-outline rounded-md">
          <img class="mr-1 inline" width="32" height="32" src={`${base}logo.svg`} alt="Safraz Razik" />
          <span class="text-muted align-middle text-xl font-bold">Safraz Razik</span>
        </a>
        <p class="text-muted text-base">
          AI-accelerated software engineering. 15+ years of full-stack development and startup co-founding.
        </p>
        <p class="text-muted text-sm">&copy; {new Date().getFullYear()} Safraz Razik / Zetmel</p>
      </div>

      <div class="grid max-w-xl flex-1 grid-cols-1 gap-8 sm:grid-cols-3">
        <div class="flex flex-col gap-4">
          <p class="text-base font-medium">Pages</p>
          <ul role="list" class="flex flex-col gap-3">
            <li><a href="/work/" class="text-link">Work</a></li>
            <li><a href="/lab/" class="text-link">AI Lab</a></li>
            <li><a href="/writing/" class="text-link">Writing</a></li>
            <li><a href="/about/" class="text-link">About</a></li>
            <li><a href="/resume/" class="text-link">Resume</a></li>
          </ul>
        </div>
        <div class="flex flex-col gap-4">
          <p class="text-base font-medium">Contact</p>
          <ul role="list" class="flex flex-col gap-3">
            <li><a href="mailto:safrazik@zetmel.com" class="text-link">safrazik@zetmel.com</a></li>
            <li><a href="https://linkedin.com/in/safrazik" class="text-link" target="_blank" rel="noopener noreferrer">LinkedIn <ExternalLinkIcon class="h-4 w-4" aria-hidden="true" /></a></li>
            <li><a href="https://github.com/safrazik" class="text-link" target="_blank" rel="noopener noreferrer">GitHub <ExternalLinkIcon class="h-4 w-4" aria-hidden="true" /></a></li>
          </ul>
        </div>
        <div class="flex flex-col gap-4">
          <p class="text-base font-medium">More</p>
          <ul role="list" class="flex flex-col gap-3">
            <li><a href="/legal/" class="text-link">Legal notice</a></li>
            <li><a href="/privacy/" class="text-link">Privacy policy</a></li>
            <li><a href="/styleguide/" class="text-link">Style guide</a></li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</footer>
