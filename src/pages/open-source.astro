---
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { Hero } from '@/components/hero';
import LetterGlitchBand from '@/components/patterns/LetterGlitchBand.astro';
---

<PageLayout
  title="Open Source \u2014 Safraz Razik"
  description="Open-source projects by Safraz Razik, including Vue File Agent, Rockplate, and more."
  includePersonSchema={true}
  footerBackground="secondary"
>
  <Hero layout="centered" size="sm" class="isolate" showHeroHalo>
    <Badge slot="badge" variant="brand" pill>
      <Icon name="code-2" size="sm" />
      Open Source
    </Badge>
    <h1 slot="title">Tools I've built</h1>
    <p slot="description">
      Developer tooling has been a recurring part of my career\u2014from early generators and internal frameworks
      to Vue File Agent and Rockplate. These projects reflect how I approach engineering: remove friction,
      create reusable systems and make complex work easier to understand.
    </p>
  </Hero>

  <section class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="grid gap-6 md:grid-cols-2">
        <Card variant="elevated" padding="lg" hover={true} href="https://github.com/safrazik/vue-file-agent" target="_blank" rel="noopener noreferrer" class="flex flex-col gap-4" data-reveal>
          <div class="flex items-center gap-3">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand-500/10 text-brand-500">
              <Icon name="upload" size="lg" />
            </div>
            <div>
              <h2 class="font-display text-xl font-bold text-foreground">Vue File Agent</h2>
              <p class="text-sm text-foreground-muted">700+ stars on GitHub</p>
            </div>
          </div>
          <p class="text-foreground-muted leading-relaxed">
            A high-performance Vue file-upload component with drag-and-drop, validation, previews, upload progress,
            server-side error handling, sorting and resumable-upload support. Built with a plugin-based architecture
            separating core file logic from UI renderers.
          </p>
          <div class="flex flex-wrap gap-2 mt-auto">
            <span class="rounded-md bg-brand-500/10 px-2.5 py-1 text-xs font-medium text-brand-600">Vue.js</span>
            <span class="rounded-md bg-brand-500/10 px-2.5 py-1 text-xs font-medium text-brand-600">JavaScript</span>
            <span class="rounded-md bg-brand-500/10 px-2.5 py-1 text-xs font-medium text-brand-600">Open Source</span>
          </div>
        </Card>

        <Card variant="elevated" padding="lg" hover={true} href="https://github.com/rockplate/rockplate" target="_blank" rel="noopener noreferrer" class="flex flex-col gap-4" data-reveal>
          <div class="flex items-center gap-3">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand-500/10 text-brand-500">
              <Icon name="code" size="lg" />
            </div>
            <div>
              <h2 class="font-display text-xl font-bold text-foreground">Rockplate</h2>
              <p class="text-sm text-foreground-muted">Template engine + VS Code extension</p>
            </div>
          </div>
          <p class="text-foreground-muted leading-relaxed">
            A next-generation programming language for templates with a dedicated VS Code extension providing
            syntax highlighting and linting. Demonstrates lexer/AST, language-design and developer-experience
            interests beyond ordinary application development.
          </p>
          <div class="flex flex-wrap gap-2 mt-auto">
            <span class="rounded-md bg-brand-500/10 px-2.5 py-1 text-xs font-medium text-brand-600">JavaScript</span>
            <span class="rounded-md bg-brand-500/10 px-2.5 py-1 text-xs font-medium text-brand-600">Node.js</span>
            <span class="rounded-md bg-brand-500/10 px-2.5 py-1 text-xs font-medium text-brand-600">VS Code</span>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <section class="relative z-10 py-[var(--space-section-md)] bg-background">
    <div class="glitch:hidden mx-auto max-w-2xl px-6 text-center" data-reveal>
      <Badge variant="brand" pill class="mb-6">More projects</Badge>
      <h2 class="font-display text-4xl font-bold text-foreground mb-4 text-balance">More on GitHub</h2>
      <p class="text-lg text-foreground-muted mb-8 text-balance">
        Browse my GitHub profile for additional projects, contributions and experiments spanning developer tools,
        frameworks, build utilities and more.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button size="lg" href="https://github.com/safrazik" target="_blank" rel="noopener noreferrer">
          <Icon name="github" size="sm" />
          View GitHub Profile
          <Icon name="external-link" size="sm" />
        </Button>
      </div>
    </div>

    <LetterGlitchBand>
      <h2 class="font-display text-4xl font-bold text-foreground mb-4 text-balance">More on GitHub</h2>
      <p class="text-lg text-foreground-muted mb-8 text-balance">
        Browse my GitHub profile for additional projects, contributions and experiments.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button size="lg" href="https://github.com/safrazik" target="_blank" rel="noopener noreferrer">
          <Icon name="github" size="sm" />
          View GitHub Profile
          <Icon name="external-link" size="sm" />
        </Button>
      </div>
    </LetterGlitchBand>
  </section>
</PageLayout>
