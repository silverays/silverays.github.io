---
/**
 * AboutView — the About page body.
 *
 * Shared by the default-locale route (`/about`) and the locale-prefixed route
 * (`/<locale>/about`). All copy is read from the `pages.about.*` keys in the
 * locale dictionaries (`src/i18n/<locale>.json`) via `t()` / `tData()`, so
 * translating the page is a matter of editing JSON — no markup changes — and
 * any untranslated key falls back to the default locale automatically.
 *
 * Rendering with the default locale produces the same markup the page had
 * before this was extracted.
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import ProofTile from '@/components/ui/data-display/ProofTile/ProofTile.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { Hero } from '@/components/hero';
import TypingEffect from '@/components/ui/TypingEffect.astro';
import TechStack from '@/components/landing/TechStack.astro';
import LetterGlitchBand from '@/components/patterns/LetterGlitchBand.astro';
import { t, tData, defaultLocale } from '@/i18n';

interface Props {
  /** Locale whose copy this page renders. Defaults to the site default. */
  locale?: string;
}

interface IconText {
  icon: string;
  title: string;
  description: string;
}
interface FaqItem {
  question: string;
  answer: string;
}
interface FaqCard {
  icon: string;
  title: string;
  items: FaqItem[];
}
interface TitleText {
  title: string;
  text: string;
}

const { locale = defaultLocale } = Astro.props;

const GITHUB_URL = 'https://github.com/hansmartensdev/astro-rocket';

const hero = tData<{ badge: string; titleLead: string; typingWords: string[]; description: string }>(
  'pages.about.hero',
  locale
)!;
const intro = tData<{ badge: string; heading: string; paragraphs: string[]; facts: IconText[] }>(
  'pages.about.intro',
  locale
)!;
const principles = tData<{ badge: string; heading: string; lead: string; items: IconText[] }>(
  'pages.about.principles',
  locale
)!;
const stack = tData<{ badge: string; title: string; description: string }>('pages.about.stack', locale)!;
const faq = tData<{ badge: string; heading: string; lead: string; cards: FaqCard[] }>('pages.about.faq', locale)!;
const openSource = tData<{
  badge: string;
  heading: string;
  description: string;
  button: string;
  cards: TitleText[];
}>('pages.about.openSource', locale)!;
const cta = tData<{ badge: string; heading: string; description: string; button: string }>('pages.about.cta', locale)!;
---
<PageLayout
  title={t('pages.about.meta.title', locale)}
  description={t('pages.about.meta.description', locale)}
  footerBackground="secondary"
  includePersonSchema={true}
>
  <Hero layout="centered" size="sm" class="isolate" showHeroHalo>
    <Badge slot="badge" variant="brand" pill>
      <Icon name="rocket" size="sm" />
      {hero.badge}
    </Badge>
    <h1 slot="title">
      <span class="text-foreground [-webkit-text-fill-color:currentColor]">{hero.titleLead}</span><br />
      <span class="text-brand-500 [-webkit-text-fill-color:var(--color-brand-500)]">
        <TypingEffect words={hero.typingWords} />
      </span>
    </h1>

    <p slot="description">
      {hero.description}
    </p>
  </Hero>

  <!-- About the theme -->
  <section class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-10 glitch:grid-cols-2 glitch:gap-12">
        <!-- Left: text -->
        <div class="flex flex-col justify-center gap-4 sm:items-center sm:text-center glitch:items-start glitch:text-left" data-reveal data-reveal-eager data-reveal-ease="smooth">
          <div class="flex flex-col gap-6 sm:items-center glitch:items-start">
            <Badge variant="brand" pill class="self-start sm:self-center glitch:self-start">{intro.badge}</Badge>
            <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground text-balance">
              {intro.heading}
            </h2>
          </div>
          {intro.paragraphs.map((paragraph) => (
            <p class="text-lg text-foreground-muted leading-relaxed sm:max-w-xl sm:mx-auto glitch:max-w-none glitch:mx-0">
              {paragraph}
            </p>
          ))}
        </div>
        <!-- Right: theme facts card -->
        <div class="flex flex-col h-full" data-reveal data-reveal-eager data-reveal-ease="smooth">
          <Card variant="elevated" padding="lg" class="flex-1 flex flex-col justify-center">
            <div class="grid grid-cols-2 sm:grid-cols-3 glitch:grid-cols-2 gap-3 auto-rows-fr">
              {intro.facts.map((fact) => (
                <ProofTile icon={fact.icon} title={fact.title}>
                  {fact.description}
                </ProofTile>
              ))}
            </div>
          </Card>
        </div>
      </div>
    </div>
  </section>

  <!-- Principles -->
  <section class="py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-8 text-center flex flex-col items-center gap-4" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill>{principles.badge}</Badge>
          <h2 class="font-display text-4xl font-bold text-foreground">
            {principles.heading}
          </h2>
        </div>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto text-balance">
          {principles.lead}
        </p>
      </div>
      <div class="grid gap-6 sm:grid-cols-3">
        {principles.items.map((item, i) => (
          <ProofTile icon={item.icon} title={item.title} data-reveal data-reveal-delay={i || undefined}>
            {item.description}
          </ProofTile>
        ))}
      </div>
    </div>
  </section>

  <!-- Tech Stack -->
  <TechStack
    badge={stack.badge}
    title={stack.title}
    description={stack.description}
    background="secondary"
  />

  <!-- Beyond Software -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-10 glitch:grid-cols-2 glitch:gap-12">
        <div class="flex flex-col justify-center sm:items-center sm:text-center glitch:items-start glitch:text-left" data-reveal data-reveal-ease="smooth">
          <div class="flex flex-col gap-6 mb-6 sm:items-center glitch:items-start">
            <Badge variant="brand" pill class="self-start sm:self-center glitch:self-start">Beyond Software</Badge>
            <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
              Engineering curiosity <br class="sm:hidden" /><span class="text-brand-500">beyond the screen</span>
            </h2>
          </div>
          <p class="text-lg text-foreground-muted leading-relaxed mb-4 sm:mb-0 sm:max-w-xl glitch:mb-4 glitch:max-w-none">
            My engineering interests extend into electronics, IoT and smart devices.
            I enjoy connecting software with physical controls, sensors and automation\u2014from
            custom Arduino systems to smart-home experiments.
          </p>
        </div>
        <Card variant="elevated" padding="lg" class="h-full flex flex-col" data-reveal data-reveal-delay="1" data-reveal-ease="smooth">
          <div class="grid grid-cols-2 gap-3 flex-1 auto-rows-fr">
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center justify-center text-center gap-2 border-t-2 border-brand-500/40 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default h-full">
              <svg class="w-8 h-8 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 3.75H6.912a2.25 2.25 0 00-2.15 1.588L2.35 13.177a2.25 2.25 0 00-.1.661V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18v-4.162c0-.224-.034-.447-.1-.661L19.24 5.338a2.25 2.25 0 00-2.15-1.588H15M2.25 13.5h3.86a2.25 2.25 0 012.012 1.244l.256.512a2.25 2.25 0 002.013 1.244h3.218a2.25 2.25 0 002.013-1.244l.256-.512a2.25 2.25 0 012.013-1.244h3.859" />
              </svg>
              <span class="text-sm font-semibold text-foreground">Electronics</span>
            </div>
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center justify-center text-center gap-2 border-t-2 border-brand-500/40 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default h-full">
              <svg class="w-8 h-8 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h9m-4.5 9L12 21m0 0L7.5 12m4.5 9h9M3 12l4.5 4.5M12 3l4.5 4.5M21 12l-4.5-4.5M12 3v18m4.5-4.5L12 21" />
              </svg>
              <span class="text-sm font-semibold text-foreground">IoT</span>
            </div>
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center justify-center text-center gap-2 border-t-2 border-brand-500/40 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default h-full">
              <svg class="w-8 h-8 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />
              </svg>
              <span class="text-sm font-semibold text-foreground">Arduino</span>
            </div>
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center justify-center text-center gap-2 border-t-2 border-brand-500/40 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default h-full">
              <svg class="w-8 h-8 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z" />
              </svg>
              <span class="text-sm font-semibold text-foreground">Smart Devices</span>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill>{faq.badge}</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
            {faq.heading}
          </h2>
        </div>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto text-balance">
          {faq.lead}
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        {faq.cards.map((card, cardIndex) => (
          <Card variant="elevated" padding="lg" data-reveal data-reveal-delay={cardIndex + 1}>
            <div class="flex items-center gap-3 pb-4 border-b border-border">
              <div class="w-11 h-11 rounded-lg bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                <Icon name={card.icon} size="md" />
              </div>
              <h3 class="font-display text-base font-semibold text-foreground">{card.title}</h3>
            </div>
            <div class="w-full">
              {card.items.map((item) => (
                <details class="border-b border-border last:border-0" name={`faq-${cardIndex}`}>
                  <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                    {item.question}
                    <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
                  </summary>
                  <div class="pb-4 text-sm text-foreground-muted leading-relaxed" set:html={item.answer} />
                </details>
              ))}
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Open Source -->
  <section class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-8 sm:gap-10 glitch:grid-cols-2 glitch:items-center">
        <!-- Text -->
        <div class="flex flex-col gap-4 sm:items-center sm:text-center glitch:items-start glitch:justify-center glitch:text-left" data-reveal data-reveal-ease="smooth">
          <Badge variant="brand" pill class="self-start sm:self-center glitch:self-start">{openSource.badge}</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
            {openSource.heading}
          </h2>
          <p class="text-lg text-foreground-muted leading-relaxed sm:max-w-xl sm:mx-auto glitch:max-w-none glitch:mx-0">
            {openSource.description}
          </p>
          <div class="flex flex-wrap gap-4 self-start sm:self-center sm:justify-center glitch:self-start mt-2">
            <Button variant="outline" size="lg" href={GITHUB_URL} target="_blank" rel="noopener noreferrer">
              {openSource.button}
              <Icon name="arrow-right" size="sm" />
            </Button>
          </div>
        </div>

        <!-- Info card -->
        <div class="flex flex-col h-full" data-reveal data-reveal-delay="1" data-reveal-ease="smooth">
          <Card variant="elevated" padding="lg" class="flex-1 flex flex-col justify-center gap-6">
            {openSource.cards.map((card) => (
              <div class="flex flex-col gap-2">
                <h3 class="text-base font-semibold text-foreground">{card.title}</h3>
                <p class="text-sm text-foreground-muted leading-relaxed" set:html={card.text} />
              </div>
            ))}
          </Card>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background border-t border-border">
    <!-- Mobile: flat section, no card -->
    <div class="glitch:hidden mx-auto max-w-2xl px-6 text-center" data-reveal>
      <Badge variant="brand" pill class="mb-6">{cta.badge}</Badge>
      <h2 class="font-display text-4xl font-bold text-foreground mb-4 text-balance">
        {cta.heading}
      </h2>
      <p class="text-lg text-foreground-muted mb-8 text-balance">
        {cta.description}
      </p>
      <Button size="lg" href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="cta-btn-brand">
        {cta.button}
        <Icon name="arrow-right" size="sm" />
      </Button>
    </div>

    <!-- Desktop: contained LetterGlitch band with glass card -->
    <LetterGlitchBand>
      <h2 class="font-display text-4xl font-bold text-foreground mb-4 text-balance">
        {cta.heading}
      </h2>
      <p class="text-lg text-foreground-muted mb-8 text-balance">
        {cta.description}
      </p>
      <Button size="lg" href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="hero-btn-brand">
        {cta.button}
        <Icon name="arrow-right" size="sm" />
      </Button>
    </LetterGlitchBand>
  </section>
</PageLayout>

<style>
  details[open] > summary .faq-icon {
    transform: rotate(180deg);
  }
</style>
